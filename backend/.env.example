# ============================================================
# OnlineOrder - Environment Variables Template
# Copy this file to .env and fill in the values.
# DO NOT commit .env to version control!
# ============================================================

# ----------------------------------------------------------
# Database Configuration (Required)
# ----------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=onlineorder
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_password_here

# ----------------------------------------------------------
# Flyway Migration
# Set to true in production to enable Flyway migrations
# ----------------------------------------------------------
FLYWAY_ENABLED=false

# ----------------------------------------------------------
# JWT Configuration (CRITICAL - Required in Production)
# Generate a secure secret key:
#   openssl rand -base64 32
# Minimum 32 bytes required for HS256
# ----------------------------------------------------------
# Development: a default key for local testing only
JWT_SECRET=default-dev-secret-key-change-in-production-at-least-32-bytes
# Production: MUST be set to a unique, random secret
# JWT_SECRET=your_very_long_random_secret_here_at_least_32_bytes

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG

# ----------------------------------------------------------
# Server
# ----------------------------------------------------------
SERVER_PORT=8093
